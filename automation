#!/bin/bash
jawaban="Y"
read -p "Apakah anda yakin akan melakukan setup Apache & MySQL Server ? (Y/n)" pilih;
if [ $pilih == $jawaban ]; 
then
    echo "=======================================================Melakukan Updating====================================================>"
    echo "=============================================================================================================================>"
    sudo apt update && sudo apt upgrade -y
    echo "=======================================================Downloading Data======================================================>"
    echo "=============================================================================================================================>"
    sudo apt-get install apache2 php php-mysql -y
    echo "=============================================================================================================================>"
    echo "=============================================================================================================================>"
    sudo apt-get install mysql-server -y
    echo "=============================================================================================================================>"
    echo "=============================================================================================================================>"
    echo "Setup selesai"
    exit 0
else
    echo "Setup dibatalkan"
    exit 1
fi
